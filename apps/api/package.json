{
  "name": "trolleycheck-api",
  "version": "0.1.0",
  "description": "TrolleyCheck pilot API - Australian grocery price comparison",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "grocery",
    "price-comparison",
    "australia",
    "supermarket"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/auth-helpers-nodejs": "^0.8.0",
    "@supabase/supabase-js": "^2.38.0",
    "@types/node": "^20.10.0",
    "bcryptjs": "^2.4.3",
    "express": "^5.0.0",
    "helmet": "^7.1.0",
    "pino": "^8.17.0",
    "pino-http": "^8.6.0",
    "prisma": "^7.0.0",
    "radix3": "^1.1.0",
    "redis": "^4.6.12",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
